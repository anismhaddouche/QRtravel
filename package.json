{
  "name": "qr-checkin-mvp",
  "version": "1.0.0",
  "description": "Offline QR-based passenger check-in system for group travel",
  "private": true,
  "scripts": {
    "server": "node server/index.js",
    "server:https": "node server/index.js --https",
    "client": "cd client && npm run dev",
    "seed": "node server/seed.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "dev:https": "concurrently \"npm run server:https\" \"npm run client\"",
    "build": "cd client && npm run build",
    "start": "npm run build && npm run server",
    "generate-cert": "node server/generate-cert.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.0",
    "qrcode": "^1.5.4",
    "sql.js": "^1.11.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
