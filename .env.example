# Server (Vercel uses standard PORT for local dev)
PORT=3000
NODE_ENV=development

# URL of your Supabase PostgreSQL database
# ─── Transaction Pooler (recommended, port 6543) ───
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
#
# ─── Session Pooler (fallback if transaction pooler times out, port 5432) ───
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
#
# NOTE: Always include ?sslmode=require for Supabase connections.
DATABASE_URL=postgresql://postgres:password@localhost:5432/qrcheckin?sslmode=require

# Admin credentials for login
ADMIN_USERNAME=ADMIN
ADMIN_PASSWORD=ADMIN123
# Or provide a pre-hashed password (bcrypt):
# ADMIN_PASSWORD_HASH=$2a$10$...

# Session root secret — CHANGE THIS IN PRODUCTION
# Must be present for session cookies to be securely signed
SESSION_SECRET=dev-secret-change-me-in-production

# Local development flags
# Set to 'true' to start the local Express server instead of Vercel simulated serverless functions
LOCAL_SERVER=false
