# Server (Vercel uses standard PORT for local dev)
PORT=3000
NODE_ENV=development

# URL of your Supabase PostgreSQL database
#
# SSL is configured in code (ssl: { rejectUnauthorized: false }) — DO NOT
# append ?sslmode=require to this URL. pg's connection-string parser will
# otherwise fight the in-code SSL config and re-introduce
# "self-signed certificate in certificate chain" errors on Vercel.
#
# ─── Session Pooler (recommended first, port 5432) ───
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres
#
# ─── Transaction Pooler (fallback, port 6543) ───
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres
#
# After deploying, verify with:
#   GET /api/debug/db-env   -> confirms host/port/user (no secrets)
#   GET /api/debug/db-test  -> runs SELECT NOW() and returns ok:true on success
DATABASE_URL=postgresql://postgres:password@localhost:5432/qrcheckin

# Admin credentials for login
ADMIN_USERNAME=ADMIN
ADMIN_PASSWORD=ADMIN123
# Or provide a pre-hashed password (bcrypt):
# ADMIN_PASSWORD_HASH=$2a$10$...

# Session root secret — CHANGE THIS IN PRODUCTION
# Must be present for session cookies to be securely signed
SESSION_SECRET=dev-secret-change-me-in-production

# Local development flags
# Set to 'true' to start the local Express server instead of Vercel simulated serverless functions
LOCAL_SERVER=false

# ─── CORS allowlist (production) ───
# Comma-separated origins allowed to call /api with credentials.
# In dev, localhost/127.0.0.1 is always allowed automatically.
# Example: ALLOWED_ORIGIN=https://voyagecheck.vercel.app,https://www.example.com
ALLOWED_ORIGIN=

# ─── Debug endpoints in production ───
# /api/debug/db-env and /api/debug/db-test return 404 in production
# unless this is set to "true". Even when enabled, they require an
# authenticated admin session.
ENABLE_DEBUG_ENDPOINTS=false

# ─── Optional Upstash Redis rate limiter (auto-detected) ───
# If both vars are set the rate limiter uses Upstash for cross-instance
# accuracy. If unset, the in-memory backend is used (per-instance only).
# UPSTASH_REDIS_REST_URL=https://<your-instance>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=
