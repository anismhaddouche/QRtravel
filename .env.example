# Server
PORT=3000
NODE_ENV=development

# PostgreSQL — local development
# Install PostgreSQL locally, create a database called 'qrcheckin', or use Docker:
#   docker run --name qrcheckin-pg -e POSTGRES_DB=qrcheckin -e POSTGRES_PASSWORD=password -p 5432:5432 -d postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/qrcheckin

# Admin credentials (used on first login)
ADMIN_USERNAME=ADMIN
ADMIN_PASSWORD=ADMIN123
# Or provide a pre-hashed password (bcrypt):
# ADMIN_PASSWORD_HASH=$2a$10$...

# Session secret — CHANGE THIS IN PRODUCTION
SESSION_SECRET=dev-secret-change-me-in-production

# Optional: HTTPS for LAN camera testing
# ENABLE_HTTPS=true
# HTTPS_PORT=3443
